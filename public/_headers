# Static assets — immutable cache (hashed filenames change on each build)
/assets/*
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

# HTML pages — no cache (always get fresh index.html)
/
  Cache-Control: no-cache
  X-Content-Type-Options: nosniff

/index.html
  Cache-Control: no-cache
  X-Content-Type-Options: nosniff
